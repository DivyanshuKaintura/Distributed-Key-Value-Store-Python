[Unit]
Description=Basic KV Store (FastAPI test app)
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/raft-basic-test
ExecStart=/home/ubuntu/raft-basic-test/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
