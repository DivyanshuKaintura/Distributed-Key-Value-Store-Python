[Unit]
Description=Basic KV Store (FastAPI test app)
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/Distributed-Key-Value-Store-Python
ExecStart=/home/ubuntu/Distributed-Key-Value-Store-Python/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
